# Configuration for updater.sh — copy to .env and fill in real values.
# Defaults shown; only GITHUB_TOKEN has no default and is required.

# GitHub PAT with read:packages scope; also used for `docker login ghcr.io`.
# SSO-authorize it if the org enforces SAML.
GITHUB_TOKEN=ghp_xxxx

# Username for `docker login ghcr.io`
GHCR_USER=token

# Compose file path inside the updater container
COMPOSE_FILE=/compose/docker-compose.yml

# Env file holding the tag pins
ENV_FILE=/compose/.env

# Seconds between update cycles
POLL_INTERVAL=300

# Regex for deployable tags
TAG_PATTERN=^sha-[0-9a-f]{7,40}$

# 1 = log every check, even when up-to-date
VERBOSE=0
